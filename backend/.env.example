# ============================================================
# CONFIGURATION — LaptopStock Manager Backend
# ============================================================

# Serveur
PORT=5000
NODE_ENV=development

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=laptopstock_db

# JWT
JWT_SECRET=laptopstock_secret_key_2025
JWT_EXPIRES_IN=24h

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# ============================================================
# 🤖 IA/LLM CONFIGURATION (OLLAMA) — OPTIMISÉ
# ============================================================
# ⚡ Performance: 9s → 2-3s par rapport

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Timeouts et tokens
AI_TIMEOUT_MS=2500              # ⚡ 2.5s max (down from 4s)
AI_TEMPERATURE=0.3              # ⚡ Plus déterministe = plus rapide
AI_MAX_TOKENS=40                # ⚡ 40 tokens (down from 60)
OLLAMA_TOP_P=0.7                # ⚡ Moins exploration
OLLAMA_NUM_CTX=256              # ⚡ Meilleur équilibre
OLLAMA_KEEP_ALIVE=5m

# Données au LLM
OLLAMA_MAX_LAPTOPS=3            # ⚡ Max 3 (down from 6) = moins de contexte
OLLAMA_MAX_ITEMS=1              # ⚡ Max 1 ticket/alerte (down from 2)

# Stock management
SEUIL_STOCK_BAS=3               # Alerte si < 3 laptops dispo
